        :obesity,
        :polyuria,
        :restlessness,
        :weight_loss ;
    :hasTreatment :ConsultDoctor,
        :DietModification,
        :Exercise,
        :FollowUp,
        :HaveBalancedDiet,
        :InsulinTherapy .


    :trabalhaEm :Biblioteca_Infinita .

:escritoPor a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :Autor .

:nome a owl:DatatypeProperty ;
    rdfs:range xsd:string .

:ocorremEm a owl:ObjectProperty ;
    rdfs:domain :Evento ;
    rdfs:range :LinhaTemporal .

:pertenceA a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :Biblioteca .

:requisitam a owl:ObjectProperty ;
    rdfs:domain :Leitor ;
    rdfs:range :Livro .

:Big_Bang a :EventoHistorico,
        owl:NamedIndividual .

:Dominio_da_Energia_Livre a :EventoFuturo .

:trabalhaEm a owl:ObjectProperty ;
    rdfs:domain :Bibliotecario ;
    rdfs:range :Biblioteca .

:Agente a owl:Class .

:Cronos a :Autor,
        :Bibliotecario,
        owl:NamedIndividual .

:IA_Autoconsfiente a :EventoFuturo .

:Linha_T0 a :LinhaOriginal,
        owl:NamedIndividual .

:Linha_T1 a :LinhaAlternativa,
        owl:NamedIndividual .

:Primeira_Cidade_Submarina a :EventoFuturo .

:Renascimento a :EventoHistorico .

:refereEvento a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :Evento .

:Autor_G a :Autor ;
    :nome "Stanislaw Lem II" .

:Fim_da_Escassez a :EventoFuturo .

:Pessoa a owl:Class ;
    rdfs:subClassOf :Agente,
        owl:Thing .

:existeEm a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :LinhaTemporal .

:Autor_B a :Autor ;
    :nome "Ursula K. Le Guin II" .

:Autor_C a :Autor ;
    :nome "Philip K. Dick II" .

:Autor_D a :Autor ;
    :nome "Jorge Luis Borges II" .

:Autor_H a :Autor ;
    :nome "Margaret Atwood II" .

:Autor_I a :Autor ;
    :nome "Arthur C. Clarke II" .

:Cura_da_Mortalidade a :EventoFuturo .

:Evento a owl:Class .

:Exploracao_Espacial a :EventoHistorico .

:Crise_das_Tulipas a :EventoHistorico .

:LinhaAlternativa a owl:Class ;
    rdfs:subClassOf :LinhaTemporal ;
    owl:disjointWith :LinhaOriginal .

:LinhaOriginal a owl:Class ;
    rdfs:subClassOf :LinhaTemporal .

:LinhaTemporal a owl:Class .

:Pax_Romana a :EventoHistorico .

:Autor_F a :Autor ;
    :nome "Italo Calvino II" .

:Autor_J a :Autor ;
    :nome "H.G. Wells II" .

:Extincao_Dino a :EventoHistorico .

:Autor_A a :Autor ;
    :nome "Isaac Asimov II" .

:Biblioteca a owl:Class .

:EventoFuturo a owl:Class ;
    rdfs:subClassOf :Evento ;
    owl:disjointWith :EventoHistorico .

:Nascimento_do_Sol a :EventoHistorico .

:Autor_E a :Autor ;
    :nome "Octavia Butler II" .

:Bibliotecario a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :Biblioteca ;
            owl:onProperty :trabalhaEm ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :Pessoa .

:Livro a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :LinhaTemporal ;
            owl:onProperty :existeEm ] .

:Linha_Gama_Alt a :LinhaAlternativa .

:Viagem_Intergalactica a :EventoFuturo .

:Linha_Epsilon_Alt a :LinhaAlternativa .

:EventoHistorico a owl:Class ;
    rdfs:subClassOf :Evento .

:Autor a owl:Class ;
    rdfs:subClassOf :Pessoa .

:LivroFiccional a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ a owl:Class ;
                    owl:complementOf :EventoHistorico ] ;
            owl:onProperty :refereEvento ],
        :Livro ;
    owl:disjointWith :LivroHistorico .

:Leitor a owl:Class ;
    rdfs:subClassOf :Pessoa .

:Linha_Delta_Alt a :LinhaAlternativa .

:Linha_Alpha_0 a :LinhaOriginal .

:Biblioteca_Infinita a :Biblioteca .

:LivroHistorico a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :EventoHistorico ;
            owl:onProperty :refereEvento ],
        :Livro .

:Torre_do_Conhecimento a :Biblioteca .

:Linha_Beta_0 a :LinhaOriginal .

:Cofre_do_Tempo_Perdido a :Biblioteca .

:LivroParadoxal a owl:Class ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( [ a owl:Restriction ;
                        owl:onProperty :existeEm ;
                        owl:someValuesFrom :LinhaAlternativa ] [ a owl:Restriction ;
                        owl:onProperty :existeEm ;
                        owl:someValuesFrom :LinhaOriginal ] ) ],
        :Livro .


    :designacao "A Grande Explosão Solar de 2100" .

:Livro a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :LinhaTemporal ;
            owl:onProperty :existeEm ] .

:Biblioteca a owl:Class .

:Guerra_dos_Nanobots a :EventoFuturo ;
    :descricao "Conflito global travado inteiramente através de máquinas microscópicas programáveis." ;
    :designacao "A Guerra dos Nanobots" .

:Linha_Gama_Alt a :LinhaAlternativa .


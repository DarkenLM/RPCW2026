:Exploracao_Espacial a :EventoHistorico ;
    :descricao "O lançamento do Sputnik 1 e a subsequente corrida à Lua durante o século XX.",
        "O lançamento do Sputnik 1, marcando o início da conquista humana do espaço." ;
    :designacao "Início da Era Espacial" .

:LinhaTemporal a owl:Class .

:Linha_T1 a :LinhaAlternativa .

:Nascimento_da_IA a :EventoFuturo ;
    :descricao "O despertar da primeira consciência puramente digital e sintética." ;
